-- Array holding the text that will display once the achievemnent is achieved/what the acheivement is, saved in order
local achievementText = {"Collect All\nFreshwater Fish","Collect All\nSaltwater Fish","Collect 50 Fish","Play Match\n10 Times","Stalemate In\nTic Tac Toe\n10 Times","Win All 3\nFlapping Fish\nMaps","Pet Fish 100 Times","Get All Achievements"}
-- Array holding hint text for each of the achievements in order
local hintText = {"Freshwater\nFish","Saltwater\nFish","Have Lots\nof Fish","Match","Tic Tac Toe,\nStalemate","All Flapping\nFish Levels","That Fish\nLooks Like\nIt Could\nUse A\nBelly Rub","Get All\nAchievements"}

-- Local variables keeping track of whether an achievement has been obtained
local one = false
local two = false
local three = false
local four = false
local five = false
local six = false
local seven = false
local eight = false

-- Keeps track of the sprite name of the fiftieth pulled fish. Different name from the global variable
local fiftiethFish = ""

-- Custom Function
-- Updates Which Achievements need to be displayed
-- Checks global variables to determine if the achievement variables need to be set to true and the the nodes set to visible
local function updateAchievements()

	-- Sentinel variable set up to keep track if all achievements are achieved.
	local allAchievements = true

	-- If global FreshwaterFound is true (meaning all freshwater fish are found)
	if FreshwaterFound then
		-- Sets achievement one to true
		one = true
		-- Makes achievement one node visible
		gui.set_visible(gui.get_node("achivement1"), true)
	-- If FreshwaterFound is false
	else
		-- set allAchievements to false since they have not all been achieved.
		allAchievements = false
	end

	-- If global SaltwaterFound is true (meaning all saltwater fish are found)
	if SaltwaterFound then
		-- Sets achievement two to true
		two = true
		-- Makes achievement two node visible
		gui.set_visible(gui.get_node("achivement2"), true)
	-- If SalthwaterFound is false
	else
		-- set allAchievements to false since they have not all been achieved.
		allAchievements = false
	end

	-- If global total fish pulled is greater than or equal to 50
	if TotalFishPulled >= 50 then
		-- Set achievement three to true
		three = true
		-- Checks if the fiftieth fish set is 1, or the freshwater set
		if FiftiethFish[1] == 1 then
			-- Checks which fish in the set is the fiftieth and sets the sprite to the correct one
			
			-- Determines which fish number is in the second position of the array
			if FiftiethFish[2] == 1 then
				-- Plays the correct flipbook animation for the fish
				gui.play_flipbook(gui.get_node("achivement3"), "achievement-3-9")
				-- Sets the node to visible
				gui.set_visible(gui.get_node("achivement3"), true)
				-- Saves the name of the sprite
				fiftiethFish = "achievement-3-9"
			elseif FiftiethFish[2] == 7 then
				gui.play_flipbook(gui.get_node("achivement3"), "achievement-3-10")
				gui.set_visible(gui.get_node("achivement3"), true)
				fiftiethFish = "achievement-3-10"
			elseif FiftiethFish[2] == 2 then
				gui.play_flipbook(gui.get_node("achivement3"), "achievement-3-11")
				gui.set_visible(gui.get_node("achivement3"), true)
				fiftiethFish = "achievement-3-11"
			elseif FiftiethFish[2] == 3 then
				gui.play_flipbook(gui.get_node("achivement3"), "achievement-3-12")
				gui.set_visible(gui.get_node("achivement3"), true)
				fiftiethFish = "achievement-3-12"
			elseif FiftiethFish[2] == 8 then
				gui.play_flipbook(gui.get_node("achivement3"), "achievement-3-13")
				gui.set_visible(gui.get_node("achivement3"), true)
				fiftiethFish = "achievement-3-13"
			elseif FiftiethFish[2] == 4 then
				gui.play_flipbook(gui.get_node("achivement3"), "achievement-3-14")
				gui.set_visible(gui.get_node("achivement3"), true)
				fiftiethFish = "achievement-3-14"
			elseif FiftiethFish[2] == 6 then
				gui.play_flipbook(gui.get_node("achivement3"), "achievement-3-15")
				gui.set_visible(gui.get_node("achivement3"), true)
				fiftiethFish = "achievement-3-15"
			elseif FiftiethFish[2] == 5 then
				gui.play_flipbook(gui.get_node("achivement3"), "achievement-3-16")
				gui.set_visible(gui.get_node("achivement3"), true)
				fiftiethFish = "achievement-3-16"
			end
		-- Checks if the fiftieth fish set is 2, or the saltwater set
		elseif FiftiethFish[1] == 2 then
			-- Checks which fish in the set is the fiftieth and sets the sprite to the correct one

			-- Determines which fish number is in the second position of the array
			if FiftiethFish[2] == 4 then
				-- Plays the correct flipbook animation for the fish
				gui.play_flipbook(gui.get_node("achivement3"), "achievement-3-1")
				-- Sets the node to visible
				gui.set_visible(gui.get_node("achivement3"), true)
				-- Saves the name of the sprite
				fiftiethFish = "achievement-3-1"
			elseif FiftiethFish[2] == 5 then
				gui.play_flipbook(gui.get_node("achivement3"), "achievement-3-2")
				gui.set_visible(gui.get_node("achivement3"), true)
				fiftiethFish = "achievement-3-2"
			elseif FiftiethFish[2] == 6 then
				gui.play_flipbook(gui.get_node("achivement3"), "achievement-3-3")
				gui.set_visible(gui.get_node("achivement3"), true)
				fiftiethFish = "achievement-3-3"
			elseif FiftiethFish[2] == 7 then
				gui.play_flipbook(gui.get_node("achivement3"), "achievement-3-4")
				gui.set_visible(gui.get_node("achivement3"), true)
				fiftiethFish = "achievement-3-4"
			elseif FiftiethFish[2] == 8 then
				gui.play_flipbook(gui.get_node("achivement3"), "achievement-3-5")
				gui.set_visible(gui.get_node("achivement3"), true)
				fiftiethFish = "achievement-3-5"
			elseif FiftiethFish[2] == 3 then
				gui.play_flipbook(gui.get_node("achivement3"), "achievement-3-6")
				gui.set_visible(gui.get_node("achivement3"), true)
				fiftiethFish = "achievement-3-6"
			elseif FiftiethFish[2] == 1 then
				gui.play_flipbook(gui.get_node("achivement3"), "achievement-3-7")
				gui.set_visible(gui.get_node("achivement3"), true)
				fiftiethFish = "achievement-3-7"
			elseif FiftiethFish[2] == 2 then
				gui.play_flipbook(gui.get_node("achivement3"), "achievement-3-8")
				gui.set_visible(gui.get_node("achivement3"), true)
				fiftiethFish = "achievement-3-8"
			end
		end
	-- If FifthiestFish is false
	else
		-- set allAchievements to false since they have not all been achieved.
		allAchievements = false
	end

	-- If global MatchPlayed is greater than or equal to 10
	if MatchPlayed >= 10 then
		-- Set achievement four to true
		four = true
		-- Makes achievement four node visible
		gui.set_visible(gui.get_node("achivement4"), true)
	-- If global Match Played is less than 10
	else
		-- set allAchievements to false since they have not all been achieved.
		allAchievements = false
	end

	-- If FishTacToeStalemates are greater than or equal to 10
	if FishTacToeStalemates >= 10 then
		-- Set achievement five to true
		five = true
		-- Makes achievement five node visible
		gui.set_visible(gui.get_node("achivement5"), true)
	-- If global FishTacToeStalemates is less than 10
	else
		-- set allAchievements to false since they have not all been achieved.
		allAchievements = false
	end

	-- If each position of global courseComplete is set to one, meaning each course has been cleared
	if coursesComplete[1] == 1 and coursesComplete[2] == 1 and coursesComplete[3] == 1 then 
		-- Set achievement six to true
		six = true
		-- Makes achievement six node visible
		gui.set_visible(gui.get_node("achivement6"), true)
	-- If any position in global courseComplete is not set to one, meaning any of the courses have not been completed
	else
		-- set allAchievements to false since they have not all been achieved.
		allAchievements = false
	end

	-- If global petFish is greater than or equal to 100
	if petFish >= 100 then
		-- Set achievement seven to true
		seven = true
		-- Makes achievement seven node visible
		gui.set_visible(gui.get_node("achivement7"), true)
	-- If global petFish is less than 100
	else
		-- set allAchievements to false since they have not all been achieved.
		allAchievements = false
	end

	-- If allAchievements is true
	if allAchievements then
		-- Set achievement eight to true
		eight = true
		-- Makes achievement eight node visible
		gui.set_visible(gui.get_node("achivement8"), true)
	end
	
end

-- Executed when the script first loads
function init(self)
	-- Acquires input focus
	msg.post(".", "acquire_input_focus")
end

-- Executed when the script receives input
function on_input(self, action_id, action)

	-- Grab all of the achievements nodes
	local fish1 = gui.get_node("achivement1")
	local fish2 = gui.get_node("achivement2")
	local fish3 = gui.get_node("achivement3")
	local fish4 = gui.get_node("achivement4")
	local fish5 = gui.get_node("achivement5")
	local fish6 = gui.get_node("achivement6")
	local fish7 = gui.get_node("achivement7")
	local fish8 = gui.get_node("achivement8")

	-- Grabs highlight and hint text
	local achievementHighlight = gui.get_node("AchievementHighlight")
	local achievementHighlightText = gui.get_node("AchievementHighlightText")
	local hintTextNode = gui.get_node("HintText")

	-- If no specific input is being received
	if action_id == nil then

		-- If player is hovered over the first achievement
		if gui.pick_node(fish1, action.x, action.y) then
			-- Sets the first achievement glow visible, sets all the other glows invisible.
			gui.set_visible(gui.get_node("fish1glow"), true)
			gui.set_visible(gui.get_node("fish2glow"), false)
			gui.set_visible(gui.get_node("fish3glow"), false)
			gui.set_visible(gui.get_node("fish4glow"), false)
			gui.set_visible(gui.get_node("fish5glow"), false)
			gui.set_visible(gui.get_node("fish6glow"), false)
			gui.set_visible(gui.get_node("fish7glow"), false)
			gui.set_visible(gui.get_node("fish8glow"), false)
		-- If player is hovered over the second achievement
		elseif gui.pick_node(fish2, action.x, action.y) then
			-- Sets the second achievement glow visible, sets all the other glows invisible.
			gui.set_visible(gui.get_node("fish2glow"), true)
			gui.set_visible(gui.get_node("fish1glow"), false)
			gui.set_visible(gui.get_node("fish3glow"), false)
			gui.set_visible(gui.get_node("fish4glow"), false)
			gui.set_visible(gui.get_node("fish5glow"), false)
			gui.set_visible(gui.get_node("fish6glow"), false)
			gui.set_visible(gui.get_node("fish7glow"), false)
			gui.set_visible(gui.get_node("fish8glow"), false)
		-- If player is hovered over the third achievement
