			gui.set_visible(gui.get_node("fish1glow"), false)
			gui.set_visible(gui.get_node("fish2glow"), false)
			gui.set_visible(gui.get_node("fish3glow"), false)
			gui.set_visible(gui.get_node("fish4glow"), false)
			gui.set_visible(gui.get_node("fish5glow"), false)
			gui.set_visible(gui.get_node("fish6glow"), false)
			gui.set_visible(gui.get_node("fish7glow"), false)
			gui.set_visible(gui.get_node("fish8glow"), false)
		end
	end

	-- If the user left clicks 
	if action_id == hash("LeftClick") and action.pressed then

		-- Gets the return arrow node
		local back = gui.get_node("ReturnArrow")

		-- If the user clicks the return arrow
		if gui.pick_node(back, action.x, action.y) then

			-- Calls the loader to load the main crane screen
			msg.post("Loader:/Loader", "load Crane")

		-- If the user clicks on achievement one
		elseif gui.pick_node(fish1, action.x, action.y) then
			-- If achievement one is true
			if one then
				-- Set the highlight node to visible
				gui.set_visible(achievementHighlight, true)
				-- Set the highlight node sprite to the right sprite
				gui.play_flipbook(achievementHighlight, "achievement-1")
				-- Set the highlight text node to visible
				gui.set_visible(achievementHighlightText, true)
				-- Set the right achievement text
				gui.set_text(achievementHighlightText, achievementText[1])
			-- If achievement one is false
			else
				-- Set the highlight node to true
				gui.set_visible(achievementHighlight, true)
				-- Set the highlight node sprite to the unknown fish icon
				gui.play_flipbook(achievementHighlight, "unknown-fish")
				-- Set the highlight text node to not visible
				gui.set_visible(achievementHighlightText, false)
			end
			-- Set hint text to the right hint
			gui.set_text(hintTextNode, hintText[1])
		-- If the user clicks on achievement two
		elseif gui.pick_node(fish2, action.x, action.y) then
			-- If achievement two is true
