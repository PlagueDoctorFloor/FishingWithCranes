		elseif gui.pick_node(fish7, action.x, action.y) then
			msg.post("Loader:/Loader","load DetailedFish",{set = 2, fish = 7})
		elseif gui.pick_node(fish8, action.x, action.y) then
			msg.post("Loader:/Loader","load DetailedFish",{set = 2, fish = 8})

		end
	end
end

